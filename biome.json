{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": {
		"enabled": true
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.json",
			"!!**/node_modules",
			"!!**/.next",
			"!!**/convex/_generated"
		]
	}
}
